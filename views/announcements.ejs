<%- include('partials/header') %>

<main class="main-wrapper">
  <div class="container">
    
    <!-- Breadcrumb -->
    <div style="margin-bottom: 20px; font-size: 0.9rem; color: var(--gov-text-muted);">
      <a href="/"><i class="fa-solid fa-house"></i> Trang chủ</a> / <strong style="color: var(--gov-navy);">Thông Báo</strong>
    </div>

    <div class="gov-card">
      <div class="card-header-gov">
        <h3><i class="fa-solid fa-bullhorn"></i> THÔNG BÁO CHÍNH THỨC <%= settings.site_title %></h3>
      </div>
      <div class="card-body-gov">
        
        <!-- Search Filter -->
        <form action="/thong-bao" method="GET" style="display: flex; gap: 10px; margin-bottom: 25px; flex-wrap: wrap;">
          <input type="text" name="q" value="<%= search %>" placeholder="Nhập từ khóa tìm kiếm thông báo..." class="form-control" style="flex-grow: 1; max-width: 500px;">
          <button type="submit" class="btn-gov btn-gov-primary"><i class="fa-solid fa-magnifying-glass"></i> Tìm kiếm</button>
          <% if (search) { %>
            <a href="/thong-bao" class="btn-gov" style="background: #e0e0e0; color: #333;"><i class="fa-solid fa-xmark"></i> Xóa lọc</a>
          <% } %>
        </form>

        <% if (announcements.length === 0) { %>
          <div style="text-align: center; padding: 40px; color: var(--gov-text-muted);">
            <i class="fa-solid fa-bell-slash" style="font-size: 48px; margin-bottom: 10px; opacity: 0.5;"></i>
            <p>Không có thông báo nào được tìm thấy.</p>
          </div>
        <% } else { %>
          <div style="display: flex; flex-direction: column; gap: 18px;">
            <% announcements.forEach(item => { %>
              <div style="border: 1px solid var(--gov-border); border-left: 5px solid var(--gov-red); border-radius: 6px; padding: 20px; background: #fff; box-shadow: 0 2px 6px rgba(0,0,0,0.03);">
                <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 15px; margin-bottom: 10px; flex-wrap: wrap;">
                  <h3 style="font-size: 1.15rem; color: var(--gov-navy); line-height: 1.4;">
                    <a href="/tin-tuc/<%= item.slug %>"><%= item.title %></a>
                    <% if (item.pdf_url) { %>
                      <span style="background: #dc3545; color: #fff; padding: 3px 8px; border-radius: 4px; font-size: 0.75rem; font-weight: bold; margin-left: 8px; vertical-align: middle; display: inline-block;">
                        <i class="fa-solid fa-file-pdf"></i> Có File PDF Hồ sơ
                      </span>
                    <% } %>
                  </h3>
                  <span class="badge-gov badge-red">
                    <i class="fa-regular fa-clock"></i> <%= item.created_at %>
                  </span>
                </div>

                <p style="font-size: 0.95rem; color: #555; line-height: 1.6; margin-bottom: 15px;">
                  <%= item.summary %>
                </p>

                <div style="display: flex; justify-content: space-between; align-items: center; border-top: 1px dashed var(--gov-border); padding-top: 10px; flex-wrap: wrap; gap: 10px;">
                  <small style="color: var(--gov-text-muted);"><i class="fa-regular fa-eye"></i> <%= item.views %> lượt xem</small>
                  <div style="display: flex; gap: 10px;">
                    <% if (item.pdf_url) { %>
                      <a href="<%= item.pdf_url %>" download class="btn-gov btn-gov-sm btn-gov-red" style="padding: 4px 12px; font-size: 0.82rem;">
                        <i class="fa-solid fa-download"></i> Tải hồ sơ PDF
                      </a>
                    <% } %>
                    <a href="/tin-tuc/<%= item.slug %>" class="btn-gov btn-gov-sm btn-gov-primary" style="padding: 4px 12px; font-size: 0.82rem;">
                      Xem chi tiết thông báo <i class="fa-solid fa-arrow-right"></i>
                    </a>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
        <% } %>

      </div>
    </div>

  </div>
</main>

<%- include('partials/footer') %>
