<%- include('../partials/header') %>

<main class="main-wrapper">
  <div class="container">
    
    <div class="admin-wrapper">
      
      <!-- Admin Sidebar -->
      <aside class="admin-sidebar">
        <ul class="admin-menu">
          <li><a href="/admin"><i class="fa-solid fa-gauge"></i> Tổng quan Báo cáo</a></li>
          <li class="active"><a href="/admin/posts"><i class="fa-solid fa-newspaper"></i> Quản lý Bài viết & Tin</a></li>
          <li><a href="/admin/tenders"><i class="fa-solid fa-file-contract"></i> Quản lý Gói Thầu</a></li>
          <li><a href="/admin/services"><i class="fa-solid fa-hands-holding-child"></i> Quản lý Dịch vụ công</a></li>
          <li><a href="/admin/contacts"><i class="fa-solid fa-comments"></i> Ý kiến Phản ánh</a></li>
          <li style="margin-top: 20px; border-top: 1px solid rgba(255,255,255,0.1);"><a href="/" target="_blank"><i class="fa-solid fa-arrow-up-right-from-square"></i> Xem Cổng Công Khai</a></li>
          <li><a href="/admin/logout" style="color: #ff9999;"><i class="fa-solid fa-right-from-bracket"></i> Đăng xuất</a></li>
        </ul>
      </aside>

      <!-- Admin Content -->
      <section class="admin-content">
        
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
          <h2 style="font-family: var(--font-heading); font-size: 1.4rem; color: var(--gov-navy);">
            <%= post ? 'CHỈNH SỬA BÀI VIẾT' : 'SOẠN BÀI VIẾT / THÔNG BÁO MỚI' %>
          </h2>
          <a href="/admin/posts" class="btn-gov" style="background: #e0e0e0; color: #333;">
            <i class="fa-solid fa-arrow-left"></i> Quay lại danh sách
          </a>
        </div>

        <div style="background: white; border: 1px solid var(--gov-border); border-radius: 6px; padding: 25px; box-shadow: var(--gov-shadow);">
          
          <form action="<%= post ? '/admin/posts/edit/' + post.id : '/admin/posts/create' %>" method="POST" enctype="multipart/form-data">
            
            <div class="form-group">
              <label>Tiêu đề bài viết / thông báo <span style="color: var(--gov-red);">*</span></label>
              <input type="text" name="title" value="<%= post ? post.title : '' %>" class="form-control" placeholder="Nhập tiêu đề rõ ràng..." required>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 15px;">
              <div class="form-group">
                <label>Loại nội dung</label>
                <select name="type" class="form-control">
                  <option value="news" <%= post && post.type === 'news' ? 'selected' : '' %>>Tin tức - Sự kiện</option>
                  <option value="announcement" <%= post && post.type === 'announcement' ? 'selected' : '' %>>Thông báo chỉ đạo</option>
                </select>
              </div>

              <div class="form-group">
                <label>Chuyên mục</label>
                <select name="category_id" class="form-control">
                  <% categories.forEach(cat => { %>
                    <option value="<%= cat.id %>" <%= post && post.category_id === cat.id ? 'selected' : '' %>>
                      <%= cat.name %>
                    </option>
                  <% }); %>
                </select>
              </div>

              <div class="form-group" style="display: flex; align-items: center; margin-top: 20px;">
                <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
                  <input type="checkbox" name="is_featured" value="true" <%= post && post.is_featured ? 'checked' : '' %> style="width: 18px; height: 18px;">
                  <strong>Đánh dấu bài viết nổi bật (Hiện Banner Trang Chủ)</strong>
                </label>
              </div>
            </div>

            <!-- Hình ảnh đại diện: Tải từ máy tính HOẶC nhập Link URL -->
            <div class="form-group" style="background: #f8f9fa; padding: 18px; border-radius: 6px; border: 1px dashed var(--gov-border); margin-bottom: 20px;">
              <label style="font-weight: bold; color: var(--gov-navy); margin-bottom: 10px; display: block;">
                <i class="fa-solid fa-image"></i> Hình ảnh đại diện bài viết
              </label>
              
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; align-items: start;">
                <!-- Option 1: Upload file từ máy tính -->
                <div>
                  <label style="font-size: 0.88rem; color: #555;"><i class="fa-solid fa-desktop"></i> 1. Tải ảnh trực tiếp từ máy tính (Khuyên dùng):</label>
                  <input type="file" name="image_file" accept="image/*" class="form-control" id="image_file_input" style="padding: 8px; background: white;" onchange="handleFileSelect(this)">
                  <small style="color: #666; font-size: 0.78rem; margin-top: 4px; display: block;">Hỗ trợ định dạng: JPG, PNG, WEBP, GIF (Dung lượng tối đa 10MB).</small>
                </div>

                <!-- Option 2: Nhập URL ảnh online -->
                <div>
                  <label style="font-size: 0.88rem; color: #555;"><i class="fa-solid fa-link"></i> 2. Hoặc dán đường dẫn URL ảnh trực tuyến (Image URL):</label>
                  <input type="text" name="image_url" id="image_url_input" value="<%= post ? post.image_url : '' %>" class="form-control" placeholder="https://..." oninput="handleUrlInput(this)">
                </div>
              </div>

              <!-- Preview khung xem trước hình ảnh -->
              <div id="image_preview_box" style="margin-top: 15px; display: <%= post && post.image_url ? 'block' : 'none' %>; text-align: center; background: white; padding: 10px; border-radius: 4px; border: 1px solid #ddd;">
                <small style="display: block; color: #777; margin-bottom: 5px; font-weight: bold;">Xem trước hình ảnh đại diện:</small>
                <img id="image_preview_img" src="<%= post ? post.image_url : '' %>" alt="Preview" style="max-height: 180px; max-width: 100%; border-radius: 4px; object-fit: cover; box-shadow: 0 2px 6px rgba(0,0,0,0.15);">
              </div>
            </div>

            <script>
              function handleFileSelect(input) {
                if (input.files && input.files[0]) {
                  var reader = new FileReader();
                  reader.onload = function(e) {
                    document.getElementById('image_preview_img').src = e.target.result;
                    document.getElementById('image_preview_box').style.display = 'block';
                  }
                  reader.readAsDataURL(input.files[0]);
                }
              }

              function handleUrlInput(input) {
                if (input.value.trim() !== '') {
                  document.getElementById('image_preview_img').src = input.value.trim();
                  document.getElementById('image_preview_box').style.display = 'block';
                } else {
                  if (!document.getElementById('image_file_input').files.length) {
                    document.getElementById('image_preview_box').style.display = 'none';
                  }
                }
              }
            </script>

            <!-- File đính kèm Hồ sơ / Văn bản PDF -->
            <div class="form-group" style="background: #eef6fc; padding: 18px; border-radius: 6px; border: 1px dashed #2196f3; margin-bottom: 20px;">
              <label style="font-weight: bold; color: var(--gov-navy); margin-bottom: 10px; display: block;">
                <i class="fa-solid fa-file-pdf" style="color: #e74c3c;"></i> Tải lên File Hồ sơ / Văn bản đính kèm (.PDF, .DOCX)
              </label>
              
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; align-items: start;">
                <!-- Option 1: Upload file PDF từ máy -->
                <div>
                  <label style="font-size: 0.88rem; color: #555;"><i class="fa-solid fa-upload"></i> 1. Chọn file PDF từ máy tính:</label>
                  <input type="file" name="pdf_file" accept=".pdf,.doc,.docx" class="form-control" style="padding: 8px; background: white;">
                  <small style="color: #666; font-size: 0.78rem; margin-top: 4px; display: block;">Hỗ trợ định dạng: .PDF, .DOC, .DOCX (Dung lượng tối đa 25MB).</small>
                </div>

                <!-- Option 2: Hoặc dán URL PDF -->
                <div>
                  <label style="font-size: 0.88rem; color: #555;"><i class="fa-solid fa-link"></i> 2. Hoặc dán đường dẫn URL file đính kèm trực tuyến:</label>
                  <input type="text" name="pdf_url" value="<%= post && post.pdf_url ? post.pdf_url : '' %>" class="form-control" placeholder="https://.../ho-so.pdf">
                </div>
              </div>

              <div style="margin-top: 15px;">
                <label style="font-size: 0.88rem; color: #555;">Tên hiển thị của File đính kèm (Ví dụ: <em>Tờ khai trợ cấp xã hội.pdf</em>):</label>
                <input type="text" name="pdf_name" value="<%= post && post.pdf_name ? post.pdf_name : '' %>" class="form-control" placeholder="Nhập tên văn bản / hồ sơ hiển thị cho người dân...">
              </div>

              <% if (post && post.pdf_url) { %>
                <div style="margin-top: 10px; font-size: 0.88rem; background: #fff; padding: 8px 12px; border-radius: 4px; border: 1px solid #cce5ff;">
                  <i class="fa-solid fa-paperclip" style="color: #004085;"></i> File đính kèm hiện tại: 
                  <a href="<%= post.pdf_url %>" target="_blank" style="color: #0056b3; font-weight: bold; text-decoration: underline;">
                    <%= post.pdf_name || post.pdf_url %>
                  </a>
                </div>
              <% } %>
            </div>

            <div class="form-group">
              <label>Tóm tắt bài viết (Mô tả ngắn hiển thị ở danh sách)</label>
              <textarea name="summary" class="form-control" rows="3" placeholder="Viết 2-3 câu tóm tắt nội dung..."><%= post ? post.summary : '' %></textarea>
            </div>

            <div class="form-group">
              <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                <label style="margin-bottom: 0;">Nội dung chi tiết bài viết (Chấp nhận mã định dạng HTML hoặc văn bản thường) <span style="color: var(--gov-red);">*</span></label>
                
                <!-- Quick PDF Upload Toolbar -->
                <div style="display: flex; gap: 8px;">
                  <button type="button" onclick="triggerQuickPdfUpload('download_link')" class="btn-gov btn-gov-sm" style="background: #eef6fc; color: #0056b3; border: 1px solid #b8daff; font-size: 0.82rem; cursor: pointer;">
                    <i class="fa-solid fa-file-pdf" style="color: #e74c3c;"></i> + Chèn Nút Tải PDF
                  </button>
                  <button type="button" onclick="triggerQuickPdfUpload('embed_iframe')" class="btn-gov btn-gov-sm" style="background: #fff3cd; color: #856404; border: 1px solid #ffeeba; font-size: 0.82rem; cursor: pointer;">
                    <i class="fa-solid fa-file-contract"></i> + Chèn Khung Xem PDF
                  </button>
                </div>
              </div>

              <!-- Hidden File Input for Quick PDF Upload -->
              <input type="file" id="quick_pdf_input" style="display: none;" accept=".pdf,.doc,.docx" onchange="uploadAndInsertPdf(this)">

              <textarea id="post_content_editor" name="content" class="form-control" rows="12" placeholder="Nhập nội dung chi tiết bài viết tại đây. Sử dụng các nút chèn PDF ở góc trên bên phải để tải file .PDF và tự động chèn vào bài viết..." required><%= post ? post.content : '' %></textarea>
            </div>

            <script>
              let currentInsertMode = 'download_link';

              function triggerQuickPdfUpload(mode) {
                currentInsertMode = mode;
                document.getElementById('quick_pdf_input').click();
              }

              function uploadAndInsertPdf(input) {
                if (!input.files || !input.files[0]) return;
                const file = input.files[0];

                const formData = new FormData();
                formData.append('file', file);

                const textarea = document.getElementById('post_content_editor');

                fetch('/admin/upload-api', {
                  method: 'POST',
                  body: formData
                })
                .then(res => res.json())
                .then(data => {
                  if (data.success) {
                    let insertHtml = '';
                    if (currentInsertMode === 'embed_iframe') {
                      insertHtml = '\n\n<div class="pdf-embed-box" style="margin: 20px 0;">\n  <p style="font-weight:bold; color: #004085;"><i class="fa-solid fa-file-pdf" style="color: #dc3545;"></i> Văn bản / Hồ sơ đính kèm: ' + data.originalname + '</p>\n  <iframe src="' + data.url + '" width="100%" height="600px" style="border: 1px solid #ccc; border-radius: 6px;"></iframe>\n</div>\n\n';
                    } else {
                      insertHtml = '\n\n<p style="margin: 15px 0;"><a href="' + data.url + '" target="_blank" download style="display: inline-block; padding: 10px 18px; background: #dc3545; color: #ffffff; border-radius: 4px; text-decoration: none; font-weight: bold;"><i class="fa-solid fa-file-pdf"></i> Tải về file Hồ sơ PDF: ' + data.originalname + '</a></p>\n\n';
                    }

                    textarea.value = textarea.value + insertHtml;
                    alert('✅ Đã tải file PDF "' + data.originalname + '" lên thành công và chèn vào bài viết!');
                  } else {
                    alert('Có lỗi khi tải file: ' + (data.message || 'Thất bại'));
                  }
                  input.value = '';
                })
                .catch(err => {
                  console.error(err);
                  alert('Lỗi kết nối khi tải file PDF.');
                  input.value = '';
                });
              }
            </script>

            <button type="submit" class="btn-gov btn-gov-red" style="font-size: 1rem; padding: 12px 30px;">
              <i class="fa-solid fa-floppy-disk"></i> <%= post ? 'Lưu Thay Đổi' : 'Đăng Bài Viết Ngay' %>
            </button>
          </form>

        </div>

      </section>
    </div>

  </div>
</main>

<%- include('../partials/footer') %>
