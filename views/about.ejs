            <div style="width: 80px; height: 80px; background: #eef2f5; border-radius: 50%; margin: 0 auto 12px; display: flex; align-items: center; justify-content: center; font-size: 32px; color: var(--gov-navy);">
              <i class="fa-solid fa-user-tie"></i>
            </div>
            <h3 style="color: var(--gov-navy); font-size: 1.1rem;">Đồng chí: Nguyễn Văn Hùng</h3>
            <p style="color: var(--gov-red); font-weight: bold; font-size: 0.9rem; margin-bottom: 8px;">Trưởng Văn phòng Xã hội Xã</p>
            <p style="font-size: 0.85rem; color: var(--gov-text-muted);"><i class="fa-solid fa-phone"></i> 0918.123.456</p>
            <p style="font-size: 0.85rem; color: var(--gov-text-muted);"><i class="fa-solid fa-envelope"></i> hungnv@mythien.gov.vn</p>
          </div>

          <div style="border: 1px solid var(--gov-border); border-top: 4px solid var(--gov-navy); padding: 18px; border-radius: 6px; background: #fff; text-align: center;">
            <div style="width: 80px; height: 80px; background: #eef2f5; border-radius: 50%; margin: 0 auto 12px; display: flex; align-items: center; justify-content: center; font-size: 32px; color: var(--gov-navy);">
              <i class="fa-solid fa-user-tie"></i>
            </div>
            <h3 style="color: var(--gov-navy); font-size: 1.1rem;">Đồng chí: Trần Thị Mai</h3>
            <p style="color: var(--gov-red); font-weight: bold; font-size: 0.9rem; margin-bottom: 8px;">Phó Trưởng Văn phòng Xã hội</p>
            <p style="font-size: 0.85rem; color: var(--gov-text-muted);"><i class="fa-solid fa-phone"></i> 0918.654.321</p>
            <p style="font-size: 0.85rem; color: var(--gov-text-muted);"><i class="fa-solid fa-envelope"></i> maitt@mythien.gov.vn</p>
          </div>

          <div style="border: 1px solid var(--gov-border); border-top: 4px solid var(--gov-navy); padding: 18px; border-radius: 6px; background: #fff; text-align: center;">
            <div style="width: 80px; height: 80px; background: #eef2f5; border-radius: 50%; margin: 0 auto 12px; display: flex; align-items: center; justify-content: center; font-size: 32px; color: var(--gov-navy);">
              <i class="fa-solid fa-user"></i>
            </div>
